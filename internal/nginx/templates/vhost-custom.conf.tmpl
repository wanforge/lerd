server {
    listen 80;
    listen [::]:80;
    server_name {{.ServerNames}};

    location / {
        set $backend "{{.CustomContainer}}";
        proxy_pass {{if .BackendSSL}}https{{else}}http{{end}}://$backend:{{.CustomPort}};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $real_forwarded_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $real_forwarded_host;
        proxy_set_header X-Forwarded-Proto $real_forwarded_proto;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_read_timeout {{.RequestTimeout}}s;
        proxy_send_timeout {{.RequestTimeout}}s;
        {{- if .BackendSSL}}
        proxy_ssl_verify off;
        {{- end}}
    }

    include /etc/nginx/custom.d/{{.Domain}}.conf*;
}
